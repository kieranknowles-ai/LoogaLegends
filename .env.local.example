# Copy this to .env.local and fill in.

# Your FPL classic league numeric ID (in the URL: /leagues/{id}/standings/c)
LEAGUE_ID=375288

# Supabase project keys (Settings → API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ... (anon public key)
SUPABASE_SERVICE_ROLE_KEY=eyJ... (service_role key — KEEP SECRET, server-only)

# Random string used to authorise the cron route. Generate with: openssl rand -hex 32
CRON_SECRET=
